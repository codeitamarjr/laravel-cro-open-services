{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "codeitamarjr/laravel-cro-api",
    "description": "Laravel wrapper for the Irish CRO API with helpers for searching companies and submissions.",
    "type": "library",
    "version": "0.1.0",
    "license": "MIT",
    "keywords": [
        "laravel",
        "cro",
        "api",
        "register",
        "ireland"
    ],
    "support": {
        "issues": "https://github.com/codeitamarjr/laravel-cro-api/issues",
        "source": "https://github.com/codeitamarjr/laravel-cro-api"
    },
    "require": {
        "php": "^8.1",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Codeitamarjr\\LaravelCroApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codeitamarjr\\LaravelCroApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codeitamarjr\\LaravelCroApi\\CroApiServiceProvider"
            ],
            "aliases": {
                "CroApi": "Codeitamarjr\\LaravelCroApi\\Facades\\CroApi"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
