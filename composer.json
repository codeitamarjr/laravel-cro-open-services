{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "codeitamarjr/laravel-cro-open-services",
    "description": "Laravel SDK for Ireland's CRO Open Services API.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "cro-open-services",
        "companies-registration-office",
        "register",
        "ireland",
        "open-services"
    ],
    "support": {
        "issues": "https://github.com/codeitamarjr/laravel-cro-open-services/issues",
        "source": "https://github.com/codeitamarjr/laravel-cro-open-services"
    },
    "require": {
        "php": "^8.1",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Codeitamarjr\\LaravelCroOpenServices\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codeitamarjr\\LaravelCroOpenServices\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:live": "CRO_OPEN_SERVICES_LIVE_TESTS=1 vendor/bin/phpunit --group live"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codeitamarjr\\LaravelCroOpenServices\\CroOpenServicesServiceProvider"
            ],
            "aliases": {
                "CroOpenServices": "Codeitamarjr\\LaravelCroOpenServices\\Facades\\CroOpenServices"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
